# QR Pro API — Variáveis de Ambiente
# Copie para .env e preencha

# PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/qrpro
SPRING_DATASOURCE_USERNAME=qrpro
SPRING_DATASOURCE_PASSWORD=senha_segura

# Redis
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# JWT (openssl rand -base64 64)
JWT_SECRET=chave_super_secreta_64_bytes
JWT_EXPIRATION=86400000

# QR
QR_BASE_URL=http://localhost:8080

# Cloudflare R2
R2_ACCESS_KEY_ID=sua_key
R2_SECRET_ACCESS_KEY=sua_secret
R2_PUBLIC_URL=https://pub-seu-id.r2.dev

# Stripe (use sk_test_ em dev)
STRIPE_SECRET_KEY=sk_test_sua_chave
STRIPE_WEBHOOK_SECRET=whsec_sua_chave

# Servidor
PORT=8080
SPRING_PROFILES_ACTIVE=dev
