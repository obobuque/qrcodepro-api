# QR Pro API — Exemplo de Variáveis de Ambiente
# Copie para .env e preencha os valores

# ============================================
# BANCO DE DADOS (PostgreSQL)
# ============================================
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/qrpro
SPRING_DATASOURCE_USERNAME=qrpro
SPRING_DATASOURCE_PASSWORD=senha_segura_aqui

# ============================================
# REDIS (Upstash ou local)
# ============================================
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
# SPRING_DATA_REDIS_PASSWORD= (opcional para local)

# ============================================
# JWT
# ============================================
# Gere com: openssl rand -base64 64
JWT_SECRET=chave_super_secreta_de_64_bytes_ou_mais_aqui_nao_use_isso
JWT_EXPIRATION=86400000

# ============================================
# QR CODE
# ============================================
QR_BASE_URL=http://localhost:8080

# ============================================
# CLOUDFLARE R2 (Storage de imagens)
# ============================================
R2_ACCESS_KEY_ID=sua_access_key
R2_SECRET_ACCESS_KEY=sua_secret_key
R2_PUBLIC_URL=https://pub-seu-id.r2.dev

# ============================================
# STRIPE (Pagamentos)
# ============================================
# Use chaves de teste em dev: sk_test_...
STRIPE_SECRET_KEY=sk_test_sua_chave_de_teste
STRIPE_WEBHOOK_SECRET=whsec_sua_chave_de_webhook

# ============================================
# SERVIDOR
# ============================================
PORT=8080

# ============================================
# PERFIL SPRING (dev | prod)
# ============================================
SPRING_PROFILES_ACTIVE=dev
