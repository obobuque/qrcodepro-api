spring:
  datasource:
    url: ${SPRING_DATASOURCE_URL:jdbc:postgresql://localhost:5432/qrpro}
    username: ${SPRING_DATASOURCE_USERNAME:qrpro}
    password: ${SPRING_DATASOURCE_PASSWORD:YOUR_DB_PASSWORD}
    driver-class-name: org.postgresql.Driver
    hikari:
      maximum-pool-size: 10
      minimum-idle: 5
  data:
    redis:
      host: ${SPRING_DATA_REDIS_HOST:localhost}
      port: ${SPRING_DATA_REDIS_PORT:6379}
      timeout: 2000ms
  jpa:
    show-sql: true

minio:
  endpoint: ${MINIO_ENDPOINT:http://localhost:9000}
  access-key: ${MINIO_ACCESS_KEY:YOUR_MINIO_PASSWORD}
  secret-key: ${MINIO_SECRET_KEY:YOUR_MINIO_PASSWORD}
  bucket: ${MINIO_BUCKET:qrcodes}
  secure: false

jwt:
  secret: ${JWT_SECRET:YOUR_JWT_SECRET_MIN_64_CHARS}
  expiration: ${JWT_EXPIRATION:86400000}

qr:
  default-size: 300
  max-size: 2000
  default-correction-level: M
  base-url: ${QR_BASE_URL:http://localhost/r/}
